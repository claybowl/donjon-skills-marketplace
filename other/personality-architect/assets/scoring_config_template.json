{
  "$schema": "https://donjon.agency/schemas/personality-architect/scoring-config-v1.json",
  "metadata": {
    "name": "Sample SoulTrace-style Scoring Config",
    "version": "0.1.0",
    "tier": 1,
    "tier_notes": "Tier 1 = weighted sum + poor-person ERS z-scoring. Upgrade to Tier 2 (Bayesian) when N > 1000."
  },
  "scale": {
    "type": "likert_7",
    "min": 1,
    "max": 7,
    "midpoint": 4
  },
  "ers": {
    "method": "user_z_score",
    "calibration_first_n_items": 5,
    "notes": "Each user's responses are z-scored against their own mean and stddev before trait scoring. Removes most response-style noise."
  },
  "cross_loading_secondary_weight": 0.5,
