<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    macOS entitlements for a notarized Electron app.
    Copy to build/entitlements.mac.plist in your project.

    These entitlements are the minimum required for Electron + V8 + notarization.
    Remove any you don't need; add others your app requires (USB, camera, etc.).
  -->

  <!-- Required for Electron's V8 JIT compiler -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required for V8 executable memory allocation -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required for loading native Node modules -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Outbound network access (API calls, auto-update, etc.) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Inbound network access (localhost server, if your app runs one) -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Optional: access to user-selected files (common for productivity apps) -->
  <!--
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  -->

  <!-- Optional: camera access (if your app needs it) -->
  <!--
  <key>com.apple.security.device.camera</key>
  <true/>
  -->

  <!-- Optional: microphone access (if your app needs it) -->
  <!--
  <key>com.apple.security.device.microphone</key>
  <true/>
  -->
</dict>
</plist>
